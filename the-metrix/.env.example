# The Metrix - Environment Configuration
# Copy this file to .env and customize for your organization

# =============================================================================
# JIRA Configuration
# =============================================================================
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_USER_EMAIL=your.email@company.com

# =============================================================================
# GitHub Configuration
# =============================================================================
# For GitHub Enterprise, use: https://github.company.com
# For GitHub.com, use: https://github.com
GITHUB_BASE_URL=https://github.com
GITHUB_TOKEN=your_github_token_here
GITHUB_API_URL=https://api.github.com

# =============================================================================
# Metrics API Configuration
# =============================================================================
METRICS_API_URL=http://localhost:8080
METRICS_API_HOST=0.0.0.0
METRICS_API_PORT=8080

# =============================================================================
# Team Analytics App Configuration
# =============================================================================
TEAM_ANALYTICS_HOST=0.0.0.0
TEAM_ANALYTICS_PORT=8000

# =============================================================================
# Organization/Project Settings
# =============================================================================
# Primary project name for metrics tracking
PROJECT_NAME=MyProject
# Organization name
ORG_NAME=MyOrganization
# Team name
TEAM_NAME=Engineering Team

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_PATH=./metrics.db

# =============================================================================
# Optional: Repository Configuration
# =============================================================================
# Comma-separated list of work repositories (full paths or repo names)
# WORK_REPOS=/path/to/repo1,/path/to/repo2
# PRIVATE_REPOS=/path/to/private-repo

# =============================================================================
# Optional: Calendar Configuration
# =============================================================================
# Schedule B anchor date (YYYY-MM-DD)
# SCHEDULE_B_ANCHOR=2025-01-01
# Comma-separated holiday dates (YYYY-MM-DD)
# HOLIDAYS_2025=2025-01-01,2025-07-04,2025-12-25
# HOLIDAYS_2026=2026-01-01,2026-07-04,2026-12-25
